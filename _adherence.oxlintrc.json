{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "main.js",
              "ui_kits/analytics/**",
              "ui_kits/case-management/**",
              "ui_kits/compliance-center/**",
              "ui_kits/developer-portal/**",
              "ui_kits/docs-center/**",
              "ui_kits/kyb-profile/**",
              "ui_kits/mvp/**",
              "ui_kits/orchestration/**",
              "ui_kits/rules-builder/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|red|success|warn|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'red' | 'success' | 'warn' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|href|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, href, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:red|navy|outline|ghost|white)$/]",
        "message": "<Button> variant must be one of 'red' | 'navy' | 'outline' | 'ghost' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|dark|hover|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, accent, dark, hover, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DecisionPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:decision|children|style|key|ref|className|style|children)$/]",
        "message": "<DecisionPill> doesn't accept that prop. Declared props: decision, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DecisionPill'] > JSXAttribute[name.name='decision'] > Literal[value!=/^(?:approve|review|reject)$/]",
        "message": "<DecisionPill> decision must be one of 'approve' | 'review' | 'reject'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<IconChip> doesn't accept that prop. Declared props: icon, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconChip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:tint|solid|dark|plain)$/]",
        "message": "<IconChip> tone must be one of 'tint' | 'solid' | 'dark' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|as|options|placeholder|value|onChange|hint|required|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, type, as, options, placeholder, value, onChange, hint, required, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea|select)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea' | 'select'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|dash|style|key|ref|className|style|children)$/]",
        "message": "<Label> doesn't accept that prop. Declared props: children, color, dash, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|desc|dark|accent|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, desc, dark, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustScore'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|size|label|decision|style|key|ref|className|style|children)$/]",
        "message": "<TrustScore> doesn't accept that prop. Declared props: score, size, label, decision, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
